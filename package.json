{
    "name": "live-data-observatory",
    "version": "1.0.0",
    "description": "Real-time data ingestion and streaming backend",
    "main": "index.js",
    "scripts": {
        "start": "npm run build && node ./dist/index.js",
        "build": "tsc",
        "prebuild": "prisma generate",
        "dev": "ts-node-dev ./src/index.ts --watch ./*/**",
        "db:push": "prisma db push",
        "db:migrate": "prisma migrate dev",
        "db:studio": "prisma studio",
        "test": "cross-env NODE_ENV='test' jest --detectOpenHandles"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "dependencies": {
        "@prisma/adapter-pg": "^7.4.2",
        "@prisma/client": "^7.4.2",
        "axios": "^1.13.6",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "helmet": "^8.1.0",
        "morgan": "^1.10.1",
        "node-cron": "^4.2.1",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.4.0",
        "@types/node-cron": "^3.0.11",
        "@types/ws": "^8.18.1",
        "cross-env": "^10.1.0",
        "prisma": "^7.4.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.9.3"
    }
}
